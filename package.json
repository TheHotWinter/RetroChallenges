{
  "name": "retrochallenges",
  "productName": "RetroChallenges",
  "version": "1.0.0",
  "description": "RetroChallenges Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "test": "jest"
  },
  "keywords": [
    "electron",
    "retro",
    "challenges",
    "emuhawk",
    "nes",
    "gaming"
  ],
  "author": "RetroChallenges Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^24.6.4",
    "jest": "^30.3.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0"
  },
  "build": {
    "appId": "com.retrochallenges.app",
    "productName": "RetroChallenges",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "index.html",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js"
    }
  }
}
